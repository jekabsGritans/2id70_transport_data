{
  "name": "GTFS Transport Data - Python + Logica",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "work",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "postCreateCommand": "echo 'Dev container ready! Database is available at db:5432'"
}
